rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isManagerOrAdmin() {
      return signedIn() && userDoc().role in ['admin', 'manager'] && userDoc().status == 'active';
    }

    function ownsClient(clientId) {
      return signedIn()
        && firestore.get(/databases/(default)/documents/clients/$(clientId)).data.assignedEmployeeId == request.auth.uid;
    }

    // Client documents: clients/{clientId}/{fileName}
    match /clients/{clientId}/{fileName} {
      allow read: if isManagerOrAdmin() || ownsClient(clientId);
      // Write requires ownership AND a 20 MB size cap AND a safe content type.
      // All conditions are in ONE statement — multiple `allow write` lines are
      // OR-combined, so a size-only line would grant write to everyone.
      allow write: if (isManagerOrAdmin() || ownsClient(clientId))
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches(
             'application/pdf|image/.*|application/msword|application/vnd.*|text/plain'
           );
      allow delete: if isManagerOrAdmin() || ownsClient(clientId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
